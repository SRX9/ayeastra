{
  "name": "ayeastra",
  "private": true,
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ],
    "catalog": {
      "dotenv": "^17.2.2",
      "zod": "^4.1.13",
      "@types/bun": "^1.3.4",
      "lucide-react": "^0.546.0",
      "next-themes": "^0.4.6",
      "sonner": "^2.0.5",
      "@types/react-dom": "^19.2.3",
      "tailwindcss": "^4.1.18"
    }
  },
  "type": "module",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "check-types": "turbo check-types",
    "dev:native": "turbo -F native dev",
    "dev:web": "turbo -F web dev",
    "dev:server": "turbo -F server dev",
    "db:init": "turbo -F @ayeastra/db db:init",
    "db:seed": "turbo -F @ayeastra/db db:seed",
    "eval": "turbo -F @ayeastra/ai eval",
    "db:push": "turbo -F @ayeastra/db db:push",
    "db:studio": "turbo -F @ayeastra/db db:studio",
    "db:generate": "turbo -F @ayeastra/db db:generate",
    "db:migrate": "turbo -F @ayeastra/db db:migrate",
    "webhook": "npx ngrok http --url=relaxed-sadly-cardinal.ngrok-free.app 3000"
  },
  "dependencies": {
    "@ayeastra/env": "workspace:*",
    "@heroui-pro/react": "^1.0.0-beta.6",
    "@heroui/react": "^3.0.2",
    "@heroui/styles": "^3.0.2",
    "@number-flow/react": ">=0.5.0",
    "@tiptap/core": ">=3.23.6",
    "@tiptap/extension-link": ">=3.23.6",
    "@tiptap/extension-underline": ">=3.23.6",
    "@tiptap/extensions": ">=3.23.6",
    "@tiptap/pm": ">=3.23.6",
    "@tiptap/react": ">=3.23.6",
    "@tiptap/starter-kit": ">=3.23.6",
    "@tiptap/suggestion": ">=3.23.6",
    "dotenv": "catalog:",
    "embla-carousel": ">=8.6.0",
    "embla-carousel-react": ">=8.6.0",
    "marked": ">=18.0.0",
    "motion": ">=12.12.0",
    "react": ">=19.0.0",
    "react-aria-components": ">=1.18.0",
    "react-dom": ">=19.0.0",
    "react-markdown": ">=10.1.0",
    "react-resizable-panels": ">=4.10.0",
    "recharts": ">=2.0.0",
    "remark-breaks": ">=4.0.0",
    "remark-gfm": ">=4.0.0",
    "shiki": ">=4.0.0",
    "streamdown": ">=2.5.0",
    "tailwind-merge": ">=3.4.0",
    "tailwind-variants": ">=3.2.0",
    "tailwindcss": ">=4.0.0",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@ayeastra/config": "workspace:*",
    "@types/bun": "catalog:",
    "turbo": "^2.8.12",
    "typescript": "^5"
  },
  "packageManager": "bun@1.2.23",
  "trustedDependencies": [
    "heroui-pro",
    "@heroui-pro/react",
    "heroui-native-pro"
  ]
}
